{
  "family": "hdfc-playground",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::885599572607:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "hdfc-playground",
      "image": "885599572607.dkr.ecr.us-east-1.amazonaws.com/hdfc-playground:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ]
    }
  ]
}